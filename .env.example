# Copy this file to .env and fill in real values. Never commit .env.

# Groq API key (OpenAI-compatible). Get one free at https://console.groq.com
LLM_API_KEY=

# Duffel Flights API token — LIVE (request-time) offers with baggage + refund
# conditions. Free test token at https://app.duffel.com (Developers -> Access
# tokens); a test token looks like duffel_test_xxx.
DUFFEL_API_TOKEN=

# (Legacy / optional) Travelpayouts token for cached flight prices — no longer
# used by the flight tool, kept only if you want the old cached-price source.
# Free affiliate signup at https://www.travelpayouts.com
TRAVELPAYOUTS_TOKEN=
